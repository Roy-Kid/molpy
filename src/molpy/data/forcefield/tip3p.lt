# TIP3P Water Force Field (MolTemplate format)
# This file demonstrates both force field parameters and molecular structure

write_once("Force Field Parameters") {
    # Atom types for TIP3P water
    @atom:OW    # Oxygen atom
    @atom:HW    # Hydrogen atom

    # Bond types: @bond:bond_name @atom:atom1 @atom:atom2 k r0
    @bond:OW-HW    @atom:OW    @atom:HW    450.0    0.9572

    # Angle types: @angle:angle_name @atom:atom1 @atom:atom2 @atom:atom3 k theta0
    @angle:HW-OW-HW    @atom:HW    @atom:OW    @atom:HW    55.0    104.52

    # Dihedral types: @dihedral:dihedral_name @atom:atom1 @atom:atom2 @atom:atom3 @atom:atom4 k n delta
    @dihedral:HW-OW-HW-HW    @atom:HW    @atom:OW    @atom:HW    @atom:HW    0.0    1    0.0

    # Pair types: @pair:pair_name @atom:atom_type epsilon sigma
    @pair:OW    @atom:OW    0.1553    3.166
    @pair:HW    @atom:HW    0.0    0.0
}

write("Data Atoms") {
    # Molecular structure: atom_id atom_type x y z
    1 @atom:OW    0.000000    0.000000    0.000000
    2 @atom:HW    0.957200    0.000000    0.000000
    3 @atom:HW   -0.240000    0.927000    0.000000
}

write("Data Bonds") {
    # Molecular bonds: bond_id bond_type atom1_id atom2_id
    1 @bond:OW-HW    1    2
    2 @bond:OW-HW    1    3
}

write("Data Angles") {
    # Molecular angles: angle_id angle_type atom1_id atom2_id atom3_id
    1 @angle:HW-OW-HW    2    1    3
}

write("Data Dihedrals") {
    # Molecular dihedrals: dihedral_id dihedral_type atom1_id atom2_id atom3_id atom4_id
    1 @dihedral:HW-OW-HW-HW    2    1    3    2
}

write_once("In Settings") {
    # Force field style settings
    pair_style lj/cut/coul/long 10.0 12.0
    bond_style harmonic
    angle_style harmonic
    dihedral_style harmonic
    improper_style none

    # Special bonds
    special_bonds lj/coul 0.0 0.0 0.5
}

write_once("Data Boundary") {
    # Simulation box settings
    xlo xhi
    ylo yhi
    zlo zhi
}
